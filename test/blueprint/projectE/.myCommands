# INI File Processing Test Configuration for projectE
# Tests: variable substitution with undefined variables and recursive references

# Section for undefined variable tests
[ini.var]
# Test with undefined variable - should be escaped or result in empty/warning
undefined=echo "${undefined_var}"

# Test with recursive variable reference (should detect/handle infinite loop)
# This creates a potential circular reference: recursive references itself
recursive=echo "Value: ${ini.var.recursive}"

# For comparison, test a properly defined variable that is referenced
defined_ref=defined_value
use_defined=echo "${ini.var.defined_ref}"


# .myCommands for Test cases for command execution with additional arguments

[extra]
noargs=echo "Execute noargs"
single=echo "Hello $1"
multi=echo "Multiple args: $@"
varargs=echo "Variable args: $*"
quote=echo "Quoted $@"
withvar=echo "Name: $1 Age: 25"
pos1=echo "First: $1 Second: $2 Third: $3"
default=echo "With defaults"
