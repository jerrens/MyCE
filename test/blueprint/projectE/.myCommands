# INI File Processing Test Configuration for projectE
# Tests: variable substitution with undefined variables and recursive references

# Section for undefined variable tests
[ini.var]
# Test with undefined variable - should be escaped or result in empty/warning
undefined=echo "${undefined_var}"

# Test with recursive variable reference (should detect/handle infinite loop)
# This creates a potential circular reference: recursive references itself
recursive=echo "Value: ${ini.var.recursive}"

# For comparison, test a properly defined variable that is referenced
defined_ref=defined_value
use_defined=echo "${ini.var.defined_ref}"


# .myCommands for Test cases for command execution with additional arguments

[extra]
noargs=echo "Execute noargs"
single=echo "Hello $1"
multi=echo "Multiple args: $@"
varargs=echo "Variable args: $*"
quote=echo "Quoted $@"
withvar=echo "Name: $1 Age: 25"
pos1=echo "First: $1 Second: $2 Third: $3"
default=echo "With defaults"

# Test cases for remaining arguments ($@+ and $*+)
remaining.all=echo "Hello $@+! How are you today"
remaining.with.pos=echo "First: $1, Remaining: $@+"
remaining.multi.pos=echo "Start: $1 - Mid: $3 - Rest: $@+"
remaining.star=echo "All: $*+!"
remaining.starPos=echo "Start: $1; Rest: $*+; Mid: $3"

# Test cases for remaining arguments with braced syntax
remaining.braced.all=echo "Hello ${@+}! How are you today"
remaining.braced.pos=echo "First: $1, Remaining: ${@+}"
remaining.braced.multi=echo "Start: $1 - Mid: $3 - Rest: ${@+}"
remaining.braced.star=echo "All: ${*+}!"

# Test cases for named parameters
[named]
greet=echo "Hello $first ${last}"
greet.colon=echo "Hello $first ${last}"
message=echo "Message: $msg"
quoted=echo "Full name: $first $last at $location"
with.default=echo "Name: ${name:-Guest} Age: ${age:-25}"
undefined.ref=echo "Value: $undefined_param"
mixed=echo "Positional: $1, Named: $name, Remaining: $@+"
pass.through=echo "This command doesn't reference any named params"
special.colon=echo "Got: $value"
special.equals=echo "Got: $value"
special.both=echo "Got: $value"
