#!/bin/bash
# spell-checker:words dzdo sdiff MyCE mkfifo stty fflush

# Save original IFS at script start
__MYCE_ORIGINAL_IFS="$IFS"

# Trap to restore IFS on exit, error, or interrupt
trap 'IFS="$__MYCE_ORIGINAL_IFS"' EXIT INT TERM

__Author="Jerren Saunders"
__Version=26.7.23
__ExePath="$0" # Executable path as called
__ScriptName=$(basename "$0") # File name with extension
__AppDir=$(dirname "$0") # Path where script is stored
__AppName=${__ScriptName%.*} # File name without extension
__origArgs=$* # Capture all of the original arguments

# Detect the shell if possible
if [[ $(type -t ps) == "file" ]]; then
    __Shell="$( (ps -p "$PPID" -o comm= || echo "$SHELL") | basename "$(cut -d' ' -f1)" 2>/dev/null )"
fi
__Shell="${__Shell:-false}"


function print_usage() {
    includeAppInfo=${1}

    local shorthand_dryrun=""
    if [[ $__Shell == "zsh" ]]; then
        shorthand_dryrun="\?"
    else # Assume BASH
        shorthand_dryrun="? "
    fi

    cat <<EOT

This script will search the current directory tree for a file named '${MY_CUSTOM_FILE}', containing
a key that matches the first argument.  If found, the value of that key will be used instead.
This can be used to allow local overriding of certain commands to point to a container
instead of the local installed command.

USAGE:
    ${__ScriptName} [OPTIONS] [help | version | set | list [-l] [-a] [-d] [PATTERN] | KEY [args...]] [?]

        <KEY> [...args]             The key of the command to run

        list [-l] [-a] [-d] [PATTERN]  List the available command keys.
                                    Include the '-l' arg to list one key per line.  Default is column view.
                                    Include the '-a' arg to include variables (uppercase)
                                    Include the '-d' arg to show descriptions for each command.
                                    Include a PATTERN to filter the results.
                                        Use grep pattern syntax (e.g., \`my list prod\`)

        definition <key>            Identifies the file(s) the given key exist in.

        set <key> <command>         Adds or updates the 'key' to the '${MY_CUSTOM_FILE}' file in the current directory.
                                    The given command will be used whenever called from this level or a descendant.

        update [diff]               Update the script with the latest version.
                                    If 'diff' is given, then show the changes

        ${shorthand_dryrun}                          If the command ends with a '${shorthand_dryrun%%[[:space:]]}' character, then dry-run mode will be enabled.
                                    This is a special syntax for dry-run mode that can be quickly used to check the command.
                                    Then use the UP arrow to recall the previous command and easily remove the dry-run syntax for execution.

        @                           If the command ends with an '@' character, then definition preview mode will be enabled.
                                    This shows where the command is defined in the .myCommands files.

        help                        Show usage
        version                     Show version number

    OPTIONS:
        -c      Run the command without sourcing the default shell rc file
        -v      Verbose Level (Multiple may be given to increase the verbosity)
        -d      Dry Run.  A trailing '?' may also be used as a special syntax to enable dry-run mode.


EOT
    if [[ "${includeAppInfo}" = "true" ]]; then
        cat <<EOT
 By: ${__Author}
 Version: ${__Version}

EOT
    fi

    # Print options values if verbose mode
    log 2 "Parsed Options:"
    log 2 "  DryRun:  ${DRYRUN}"
    log 2 "  Definition Preview: ${DEFINITION_PREVIEW}"
    log 2 "  Verbose: ${VERBOSE}"
    log 2 "  File:    ${MY_CUSTOM_FILE}"
    log 2 "  Column:  ${COLUMN_WIDTH}"
    log 2 "  ShellRC: ${MYCE_RUNCOM}"
    log 2 ""

}

# Default Settings
VERBOSE=0
DRYRUN=false
DEFINITION_PREVIEW=false
MY_CUSTOM_FILE=${MYCE_FILE_NAME:-.myCommands}
COLUMN_WIDTH=${MYCE_COLUMN_WIDTH:-120} # If set to 'FULL', then the full terminal width will be used

if [[ -n "${__Shell}" ]] && [ "${__Shell}" != "false" ]; then
    SHELL_RC="$HOME/.${__Shell}rc"

    # if [ ! -f "${SHELL_RC}" ]; then
    #     SHELL_RC=false
    # fi
else
    SHELL_RC=false
fi

MYCE_RUNCOM=${MYCE_RUNCOM:-$SHELL_RC}

# If set to 'FULL', then unset so that the full width is used
if [[ "${COLUMN_WIDTH}" == "FULL" ]]; then
    unset COLUMN_WIDTH
fi


# Prints log message to the terminal
# Level 0 are considered "important" messages and will be printed to stdout, while levels 1 and above are considered "debug" messages and will be printed to stderr
#  <int> lvl - Print Level: Only print this message if the VERBOSE level is greater than or equal to this
#  <string> msg - Message to print
function log() {
    local lvl=$1
    local msg=$2

    if (( lvl <= VERBOSE )); then
        if (( lvl == 0 )); then
            echo -e "$msg"
        else
            echo -e "$msg" >&2
        fi
    fi
}

# Helper function to extract the first word from a command string
# Handles: quoted strings, command substitutions $(...) and `...`, 
# process substitution <(...) and >(...), escaped spaces, and complex expansions
__extract_first_word() {
    local cmd="$1"
    local word=""
    local i=0
    local len=${#cmd}
    local in_substitution=0
    local paren_depth=0
    local in_single_quote=0
    local in_double_quote=0
    local in_backtick=0
    local in_process_sub=0
    local prev_char=""
    
    while (( i < len )); do
        local char="${cmd:i:1}"
        
        # If we hit whitespace and we have a word and are not in any special context, we're done
        if [[ "$char" =~ [[:space:]] ]] && [[ -n "$word" ]] && \
           (( ! in_substitution )) && (( ! in_single_quote )) && (( ! in_double_quote )) && \
           (( ! in_backtick )) && (( ! in_process_sub )); then
            echo "$word"
            return
        fi
        
        # Skip leading whitespace if no word yet
        if [[ "$char" =~ [[:space:]] ]] && [[ -z "$word" ]]; then
            ((i++))
            continue
        fi
        
        # Handle escaped characters (backslash escapes the next character)
        # shellcheck disable=SC1003
        if [[ "$prev_char" == '\' ]] && (( ! in_single_quote )); then
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Handle single quotes (nothing special inside, including no escaping)
        if [[ "$char" == "'" ]] && (( ! in_double_quote )) && (( ! in_backtick )); then
            in_single_quote=$(( ! in_single_quote ))
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # If in single quotes, just add the character
        if (( in_single_quote )); then
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Handle double quotes
        if [[ "$char" == '"' ]] && (( ! in_backtick )); then
            in_double_quote=$(( ! in_double_quote ))
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # If in double quotes, add character (but still track special syntax inside)
        if (( in_double_quote )); then
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Handle backtick command substitution `...`
        if [[ "$char" == '`' ]]; then
            in_backtick=$(( ! in_backtick ))
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # If in backtick, add character
        if (( in_backtick )); then
            word+="$char"
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Handle command substitution $(...) 
        if [[ "$char" == '$' && "${cmd:i+1:1}" == '(' ]] && (( ! in_substitution )); then
            in_substitution=1
            paren_depth=1
            # shellcheck disable=SC2016
            word+='$('
            prev_char='('
            ((i += 2))
            continue
        fi
        
        # Track parentheses depth inside $(...) substitution
        if (( in_substitution )); then
            word+="$char"
            if [[ "$char" == '(' ]]; then
                ((paren_depth++))
            elif [[ "$char" == ')' ]]; then
                ((paren_depth--))
                if (( paren_depth == 0 )); then
                    in_substitution=0
                fi
            fi
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Handle process substitution <(...) and >(...)
        if [[ ( "$char" == '<' || "$char" == '>' ) && "${cmd:i+1:1}" == '(' ]] && (( ! in_process_sub )); then
            in_process_sub=1
            paren_depth=1
            word+="$char("
            prev_char='('
            ((i += 2))
            continue
        fi
        
        # Track parentheses depth inside <(...) or >(...) process substitution
        if (( in_process_sub )); then
            word+="$char"
            if [[ "$char" == '(' ]]; then
                ((paren_depth++))
            elif [[ "$char" == ')' ]]; then
                ((paren_depth--))
                if (( paren_depth == 0 )); then
                    in_process_sub=0
                fi
            fi
            prev_char="$char"
            ((i++))
            continue
        fi
        
        # Regular character - add to word and continue
        word+="$char"
        prev_char="$char"
        ((i++))
    done
    
    # Return whatever word we've collected
    if [[ -n "$word" ]]; then
        echo "$word"
    fi
}

# Parses content inside ${...} and determines if it is a MyCE nested invocation.
# Nested invocation form: ${commandKey arg1 arg2}
# Sets globals:
#   __nested_invocation_detected (true/false)
#   __nested_invocation_cmd
#   __nested_invocation_args
declare -g __nested_invocation_detected="false"
declare -g __nested_invocation_cmd=""
declare -g __nested_invocation_args=""
function __parse_nested_invocation_content() {
    local content="$1"

    __nested_invocation_detected="false"
    __nested_invocation_cmd=""
    __nested_invocation_args=""

    local i=0
    local len=${#content}
    local in_single_quote=0
    local in_double_quote=0
    local in_backtick=0
    local in_substitution=0
    local in_process_sub=0
    local paren_depth=0
    local prev_char=""
    local split_idx=-1

    while (( i < len )); do
        local char="${content:i:1}"

        # shellcheck disable=SC1003
        if [[ "$prev_char" == '\\' ]] && (( ! in_single_quote )); then
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ "$char" == "'" ]] && (( ! in_double_quote )) && (( ! in_backtick )); then
            in_single_quote=$(( ! in_single_quote ))
            prev_char="$char"
            ((i++))
            continue
        fi

        if (( in_single_quote )); then
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ "$char" == '"' ]] && (( ! in_backtick )); then
            in_double_quote=$(( ! in_double_quote ))
            prev_char="$char"
            ((i++))
            continue
        fi

        if (( in_double_quote )); then
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ "$char" == '`' ]]; then
            in_backtick=$(( ! in_backtick ))
            prev_char="$char"
            ((i++))
            continue
        fi

        if (( in_backtick )); then
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ "$char" == '$' && "${content:i+1:1}" == '(' ]] && (( ! in_substitution )); then
            in_substitution=1
            paren_depth=1
            prev_char='('
            ((i += 2))
            continue
        fi

        if (( in_substitution )); then
            if [[ "$char" == '(' ]]; then
                ((paren_depth++))
            elif [[ "$char" == ')' ]]; then
                ((paren_depth--))
                if (( paren_depth == 0 )); then
                    in_substitution=0
                fi
            fi
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ ( "$char" == '<' || "$char" == '>' ) && "${content:i+1:1}" == '(' ]] && (( ! in_process_sub )); then
            in_process_sub=1
            paren_depth=1
            prev_char='('
            ((i += 2))
            continue
        fi

        if (( in_process_sub )); then
            if [[ "$char" == '(' ]]; then
                ((paren_depth++))
            elif [[ "$char" == ')' ]]; then
                ((paren_depth--))
                if (( paren_depth == 0 )); then
                    in_process_sub=0
                fi
            fi
            prev_char="$char"
            ((i++))
            continue
        fi

        if [[ "$char" =~ [[:space:]] ]]; then
            split_idx=$i
            break
        fi

        prev_char="$char"
        ((i++))
    done

    # No-arg form: ${key} with no space - also a valid nested invocation.
    if (( split_idx < 0 )); then
        if [[ "$content" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]]; then
            __nested_invocation_detected="true"
            __nested_invocation_cmd="$content"
            __nested_invocation_args=""
        fi
        return 0
    fi

    local cmd_part="${content:0:split_idx}"
    local args_part="${content:split_idx}"

    # Trim whitespace around pieces
    cmd_part="${cmd_part#"${cmd_part%%[![:space:]]*}"}"
    cmd_part="${cmd_part%"${cmd_part##*[![:space:]]}"}"
    args_part="${args_part#"${args_part%%[![:space:]]*}"}"

    # Command key shape: allow section.dot.key, underscore, digits, and hyphen
    if [[ "$cmd_part" =~ ^[a-zA-Z_][a-zA-Z0-9_.-]*$ ]]; then
        __nested_invocation_detected="true"
        __nested_invocation_cmd="$cmd_part"
        __nested_invocation_args="$args_part"
    fi
}

# Shared argument application results.
declare -g __template_expanded_cmd=""
declare -ga __template_remaining_positional=()
declare -ga __template_unconsumed_named=()

# Applies positional and named arguments to a template.
# Args:
#   $1: template string
#   $2: append-through args to template output (true/false)
#   $@: invocation args
function __apply_args_to_template() {
    local template="$1"
    local append_through="${2:-false}"
    shift 2
    local args=("$@")
    local positional_args=()
    declare -A named_params
    declare -A named_param_delimiters
    declare -A referenced_names
    local out="$template"
    local max_arg_num=-1
    declare -A referenced_positions

    __template_remaining_positional=()
    __template_unconsumed_named=()

    # Extract named params first (key=value or key:value).
    local arg
    for arg in "${args[@]}"; do
        # Named params must be plain identifiers; avoid matching shell expansions
        # like $(...) or ${...} that may contain ':' and '=' characters.
        if [[ "$arg" != *'$'* ]] && [[ "$arg" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)([:=])(.*)$ ]]; then
            local param_name="${BASH_REMATCH[1]}"
            local param_delim="${BASH_REMATCH[2]}"
            local param_value="${BASH_REMATCH[3]}"

            if [[ "$param_value" =~ ^\"(.*)\"$ ]] || [[ "$param_value" =~ ^\'(.*)\'$ ]]; then
                param_value="${BASH_REMATCH[1]}"
            fi

            named_params["$param_name"]="$param_value"
            named_param_delimiters["$param_name"]="$param_delim"
        else
            positional_args+=("$arg")
        fi
    done

    args=("${positional_args[@]}")

    # Positional substitutions: $1, ${1}, ${1:-default}
    local i
    for (( i=${#args[@]}; i>0; i-- )); do
        local p_arg="${args[$i-1]}"

        if [[ "$out" =~ (^|[^\\])(\$\{?($i)(}|:-[^}\"]*\}?)?) ]]; then
            referenced_positions[$i]=1
            if (( i > max_arg_num )); then
                max_arg_num=$i
            fi
            out="${out//${BASH_REMATCH[2]}/$p_arg}"
        fi
    done

    # Remaining positional refs: $@+, $*+, ${@+}, ${*+}
    if [[ "$out" =~ (^|[^\\])\$(\{?[@*]\+\}?) ]]; then
        local remaining_args_str=""
        local idx
        for ((idx = 1; idx <= ${#args[@]}; idx++)); do
            if [[ -z "${referenced_positions[$idx]}" ]]; then
                remaining_args_str+="${args[$idx-1]} "
            fi
        done
        remaining_args_str="${remaining_args_str% }"

        out="${out//\$@+/$remaining_args_str}"
        out="${out//\$\*+/$remaining_args_str}"
        out="${out//\$\{@+\}/$remaining_args_str}"
        out="${out//\$\{*+\}/$remaining_args_str}"

        max_arg_num=${#args[@]}
    fi

    # All positional refs: $@, $*, ${@}, ${*}
    local all_args_str=""
    if [[ "$out" =~ (^|[^\\])\$(\{)?[@*](\})?[^+] ]] || [[ "$out" =~ (^|[^\\])\$(\{)?[@*](\})?$ ]]; then
        if [[ ${#args[@]} -gt 0 ]]; then
            printf -v all_args_str '%s ' "${args[@]}"
            all_args_str="${all_args_str% }"
        fi

        out="${out//\$\{@\}/$all_args_str}"
        out="${out//\$@/$all_args_str}"
        out="${out//\$\{\*\}/$all_args_str}"
        out="${out//\$\*/$all_args_str}"

        max_arg_num=${#args[@]}
    fi

    # Remaining positional args that would be left after top-level shifting.
    # If no positional refs were used, all positional args remain available.
    if (( max_arg_num < 0 )); then
        __template_remaining_positional=("${args[@]}")
    elif (( ${#args[@]} > max_arg_num )); then
        for ((i = max_arg_num + 1; i <= ${#args[@]}; i++)); do
            __template_remaining_positional+=("${args[$i-1]}")
        done
    fi

    # Named substitutions: ${name:-default}, ${name}, $name
    local param_name
    for param_name in "${!named_params[@]}"; do
        local param_value="${named_params[$param_name]}"
        local escaped_value
        escaped_value=$(printf '%s\n' "$param_value" | sed 's/[\/&]/\\&/g')

        if [[ "$out" =~ \$\{$param_name:-[^}]*\} ]]; then
            out=$(printf '%s\n' "$out" | sed "s/\\\${$param_name:-[^}]*}/$escaped_value/g")
            referenced_names["$param_name"]=1
        elif [[ "$out" =~ \$\{$param_name\} ]]; then
            out=$(printf '%s\n' "$out" | sed "s/\\\${$param_name}/$escaped_value/g")
            referenced_names["$param_name"]=1
        elif [[ "$out" =~ \$$param_name([^a-zA-Z0-9_]|$) ]]; then
            out=$(printf '%s\n' "$out" | sed "s/\\\$$param_name\\([^a-zA-Z0-9_]\\|$\)/$escaped_value\\1/g")
            referenced_names["$param_name"]=1
        fi
    done

    # Keep unconsumed named params for pass-through.
    for param_name in "${!named_params[@]}"; do
        if [[ -z "${referenced_names[$param_name]}" ]]; then
            local param_delim="${named_param_delimiters[$param_name]}"
            __template_unconsumed_named+=("${param_name}${param_delim}${named_params[$param_name]}")
        fi
    done

    # Optionally append through-args directly to template output (used by nested).
    # Always append remaining positional args so unreferenced args reach the target,
    # e.g. ${test.zsh --test-file basic} must forward --test-file basic even if
    # test.zsh has no $1/$2 placeholders.
    if [[ "$append_through" == "true" ]]; then
        if [[ ${#__template_remaining_positional[@]} -gt 0 ]]; then
            local trailing_args_str=""
            printf -v trailing_args_str '%s ' "${__template_remaining_positional[@]}"
            trailing_args_str="${trailing_args_str% }"
            out+=" $trailing_args_str"
        fi

        if [[ ${#__template_unconsumed_named[@]} -gt 0 ]]; then
            local unconsumed_named_args_str=""
            printf -v unconsumed_named_args_str '%s ' "${__template_unconsumed_named[@]}"
            unconsumed_named_args_str="${unconsumed_named_args_str% }"
            out+=" $unconsumed_named_args_str"
        fi
    fi

    __template_expanded_cmd="$out"
}

# Backward-compatible wrapper for nested expansion path.
declare -g __template_args_applied=""
function __apply_positional_args_to_template() {
    local template="$1"
    shift
    __apply_args_to_template "$template" "true" "$@"
    __template_args_applied="$__template_expanded_cmd"
}

# Expands MyCE nested invocations in the form ${key args...}.
# Missing keys are left unchanged so shell eval can handle them later if needed.
declare -g __nested_expanded_cmd=""
function __expand_nested_invocations() {
    local input_cmd="$1"
    local depth="${2:-0}"
    local max_depth=20

    if (( depth >= max_depth )); then
        log 0 "Nested invocation depth exceeded (${max_depth}) while expanding: ${input_cmd}"
        __nested_expanded_cmd="$input_cmd"
        return 1
    fi

    local output=""
    local i=0
    local len=${#input_cmd}

    while (( i < len )); do
        # shellcheck disable=SC2016
        if [[ "${input_cmd:i:2}" == '${' ]]; then
            # If the $ is preceded by a backslash it is an escape sequence; leave it intact
            # so the variable expansion loop (and ultimately eval) handles \${...} correctly.
            # shellcheck disable=SC1003
            if (( i > 0 )) && [[ "${input_cmd:i-1:1}" == '\' ]]; then
                output+="${input_cmd:i:1}"
                ((i++))
                continue
            fi
            local start=$i
            local j=$((i + 2))

            # Find the first closing brace for this ${...} token.
            while (( j < len )); do
                if [[ "${input_cmd:j:1}" == '}' ]]; then
                    break
                fi
                ((j++))
            done

            # Unclosed expression, append remainder unchanged.
            if (( j >= len )); then
                output+="${input_cmd:start}"
                break
            fi

            local token="${input_cmd:start:j-start+1}"
            local content="${input_cmd:start+2:j-start-2}"

            __parse_nested_invocation_content "$content"
            if [[ "$__nested_invocation_detected" == "true" ]] && findKey "$__nested_invocation_cmd"; then
                local nested_template="$foundKey_value"
                local nested_args=()

                if [[ -n "$__nested_invocation_args" ]]; then
                    # shellcheck disable=SC2206
                    eval "nested_args=( $__nested_invocation_args )"
                fi

                __apply_positional_args_to_template "$nested_template" "${nested_args[@]}"
                local replacement="$__template_args_applied"

                __expand_nested_invocations "$replacement" $((depth + 1))
                replacement="$__nested_expanded_cmd"

                output+="$replacement"
            else
                # Not nested syntax (or key not found) - preserve as-is.
                output+="$token"
            fi

            i=$((j + 1))
            continue
        fi

        output+="${input_cmd:i:1}"
        ((i++))
    done

    __nested_expanded_cmd="$output"
    return 0
}

while getopts 'dvc' option; do
    # echo "Option: ${option}"
    case ${option} in
        c ) MYCE_RUNCOM=false ;;
        d ) DRYRUN=true
            log 0 "---- THIS IS A DRYRUN! ----\n"
            ;;
        v ) VERBOSE=$((VERBOSE + 1)) ;;
        * ) exit 1 ;;
    esac
done
shift $((OPTIND -1)) # Remaining args will be left


# Check for the last arg to be a '?' (special dry run syntax)
if [[ "${!#}" == "?" ]]; then
    log 1 "Definition View ending detected - Enabling Dry Run mode"
    log 2 "  Arguments Before: ${*}"
    DRYRUN=true
    # Remove the last argument
    set -- "${@:1:$(($#-1))}"

    log 2 "  Arguments After: ${*}"
fi

# Check for the last arg to be a '@' (special definition preview syntax)
if [[ "${!#}" == "@" ]]; then
    log 1 "Definition Preview ending detected - Enabling Definition Preview mode"
    log 2 "  Arguments Before: ${*}"
    DEFINITION_PREVIEW=true
    # Remove the last argument
    set -- "${@:1:$(($#-1))}"

    log 2 "  Arguments After: ${*}"
fi


# Either runs the command or prints the command that would be executed if DRYRUN is 'true'
#  Command and arguments are passed as parameters
function runCMD() {
    local cmd_string=$1
    shift

    if [[ "${DRYRUN}" == "true" ]]; then
        # Look up source location and description if available (for commands from .myCommands files)
        if [[ -n "$__current_cmd" ]]; then
            local source_location="${commandLocations["$__current_cmd"]:-}"
            local desc="${commandDescriptions["$__current_cmd"]:-}"

            # Output SRC line if available
            if [[ -n "$source_location" ]]; then
                log 0 "SRC: ${source_location}"
            fi

            # Output DESC line if available
            if [[ -n "$desc" ]]; then
                log 0 "DESC: ${desc}"
            fi
        fi

        # Build the dry-run command string and escape special control characters
        dryCMD="CMD: $cmd_string"
        # Append remaining arguments if any
        if [[ $# -gt 0 ]]; then
            dryCMD="$dryCMD $*"
        fi
        # Escape raw backslash-escaped sequences so they are printed literally
        dryCMD="${dryCMD//\\n/\\\\n}"
        dryCMD="${dryCMD//\\r/\\\\r}"
        dryCMD="${dryCMD//\\t/\\\\t}"
        dryCMD="${dryCMD//\\e/\\\\e}"
        # Escape actual control characters that may be present in the command string
        dryCMD="${dryCMD//$'\r'/\\r}"
        dryCMD="${dryCMD//$'\n'/\\n}"
        dryCMD="${dryCMD//$'\t'/\\t}"
        printf '%s\n' "$dryCMD"
        return
    fi

    # For normal execution, build the full command
    log 3 "Executing: $cmd_string $*"

    # Before executing the command, run the shell rc file to support aliases and other configurations
    if [ "${MYCE_RUNCOM}" != "false" ] && [ -f "${MYCE_RUNCOM}" ]; then
        log 1 "MYCE_RUNCOM: Sourcing shell's run commands file - '${MYCE_RUNCOM}'..."
        # shellcheck source=/dev/null
        . "${MYCE_RUNCOM}" 2>/dev/null
        # Enable alias expansion if running under Bash and shopt is available
        if [ -n "$BASH_VERSION" ] && command -v shopt >/dev/null 2>&1; then
            shopt -s expand_aliases
        fi
    else
        log 1 "MYCE_RUNCOM file not found or set to 'false'"
        log 2 "MYCE_RUNCOM = ${MYCE_RUNCOM}"
    fi

    # Pre-check the first command word to provide a friendly message before eval.
    # Skip leading KEY=value tokens and allow subshell/arithmetic forms starting with '('.
    local __cmd_word
    __cmd_word=$(__extract_first_word "$cmd_string")
    
    # Skip non-command-word tokens (e.g., KEY=value assignments)
    while [[ "$__cmd_word" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; do
        # This word is an assignment, skip it and find the next word
        local remainder="${cmd_string#*"$__cmd_word"}"
        __cmd_word=$(__extract_first_word "$remainder")
    done

    if [[ -n "$__cmd_word" ]] && [[ "$__cmd_word" != \(* ]]; then
        # For paths (containing / or ~), check if file exists and is executable
        # For other commands, use 'type' to find them in PATH or as shell functions
        if [[ "$__cmd_word" == */* ]] || [[ "$__cmd_word" == ~* ]]; then
            # Expand tilde and check if file exists and is executable
            local __expanded_path="${__cmd_word/\~/$HOME}"
            
            # If the path contains unevaluated variables/substitutions, evaluate it safely
            if [[ "$__expanded_path" == *\$* ]]; then
                __expanded_path=$(eval echo "$__expanded_path" 2>/dev/null) || __expanded_path=""
            fi
            
            # Only validate if we have a concrete path (no unevaluated variables)
            if [[ -n "$__expanded_path" ]] && [[ ! "$__expanded_path" == *\$* ]]; then
                if [[ ! -x "$__expanded_path" ]]; then
                    log 0 "Unknown key or command. See \`'$__AppName' list\` for known keys"
                    return 127
                fi
            fi
        elif ! type -t "$__cmd_word" >/dev/null 2>&1; then
            log 0 "Unknown key or command. See \`'$__AppName' list\` for known keys"
            return 127
        fi
    fi

    # Execute the command directly to preserve TTY context and allow ANSI color codes
    # NOTE: eval is intentional here — needed to expand aliases after sourcing the shell rc file.
    # shellcheck disable=SC2294
    eval "$cmd_string" "$@"
    local exit_code=$?

    # If the exit code is 127, it means a "command not found" from the shell
    # In this case, provide a helpful message where the user can discover available commands
    if [[ $exit_code -eq 127 ]]; then
        log 0 "Unknown key or command. See \`'$__AppName' list\` for known keys"
    fi

    return $exit_code
}

# Function to add or update a key-value pair in an INI file
# Usage: set_ini_value INI_FILE "section.key" "value"
#
# Example usage:
# set_ini_value "config.ini" "section.key" "value"
# set_ini_value "config.ini" "key" "value"
function set_ini_value() {
    local ini_file=$1
    local key=$2
    local value=$3
    local section=""

    # Check if the key contains a section
    if [[ "$key" == *.* ]]; then
        # Extract section and key name
        section="${key%%.*}"
        key="${key#*.}"
        log 1 "Section Key identified - Section: '${section}', Key: '${key}'"
    else
        log 1 "Key identified - Key: '${key}'"
    fi

    # If the section is not empty, handle section
    if [[ -n $section ]]; then
        log 1 "Adding key to section ${section}..."

        # Set the awk debug prints if at verbose 2 or higher
        if [[ ${VERBOSE} -ge 2 ]]; then awkLogOut=/dev/stderr; else awkLogOut=/dev/null; fi

        # Add or update the key within the section
        awk -v section="$section" -v key="$key" -v value="$value" -v ts="$(date)" -v user="$USER" -v logOut="$awkLogOut" '
            BEGIN {
                found_section=0;
                found_key=0;
            }

            !found_key {print "  Inspecting line " NR ": " $0 > logOut}


            # Match the target section header
            /^\['"$section"'\]/ {
                print "Found Target Section at line " NR > logOut
                found_section=1;
                print;
                next;
            }

            # If we are in the target section and we find the key, update its value
            found_section && $1 ~ "^" key "=" {
                print "Found Section Key at line " NR > logOut
                print key"="value;
                found_key=1;
                next;
            }

            # If we find a new section header and we have not found the key, add it
            found_section && /^\[.*\]/ && !found_key {
                print "Reached section " $section " on line " NR " without detected existing key - Inserting" > logOut
                print "# Inserted via set command by " user " on " ts;
                print key"="value"\n";
                found_key=1;
            }

            # Print all other lines
            {print}

            # If the end of the file is reached and we have not found the key, add it
            END {
                if (!found_section) {
                    print "  New section for this file!  Adding" > logOut
                    print "\n[" section "]"
                }
                if (!found_key) {
                    print "# Inserted via set command by " user " on " ts;
                    print key"="value
                }
            }
        ' "$ini_file" > "$ini_file.tmp"

    else
        # Handle keys without section
        log 1 "Adding/Updating key (no section) ..."

        # Set the awk debug prints if at verbose 2 or higher
        if [[ ${VERBOSE} -ge 2 ]]; then awkLogOut=/dev/stderr; else awkLogOut=/dev/null; fi

        # Key does not exist, add it before the first section (or the end)
        awk -v key="$key" -v value="$value" -v ts="$(date)" -v user="$USER" -v logOut="$awkLogOut" '
            BEGIN {
                added=0
            }

            # Print line for debugging
            !added {print "  Inspecting line " NR ": " $0 > logOut}

            # If new key starts with uppercase (it is a variables, not a command), then keep above the commands
            !added && key ~ "^[A-Z]" && $1 ~ "^[a-z]" {
                print "Appending VARIABLE before first command" NR > logOut
                print "# Inserted via set command by " user " on " ts;
                print key"="value"\n";
                added=1
            }

            # If we have not reached a section header and we find the key, update its value
            !added && $1 ~ "^" key "=" {
                print "    Found Existing Key at line " NR > logOut
                print key"="value;
                added=1;
                next;
            }

            # If we reach a header before finding the key, then add it
            /^\[.*\]/ && !added {
                print "    Reached section " $section " on line " NR " without detected existing key - Inserting" > logOut
                print "# Inserted via set command by " user " on " ts;
                print key"="value"\n";
                added=1
            }

            # Print all other lines
            {print}

            END {
                if (!added) {
                    print "# Inserted via set command by " user " on " ts;
                    print key"="value "\n"
                }
            }
        ' "$ini_file" > "$ini_file.tmp"
    fi

    # Either print the temp file (DryRun) or set the command file
    if [[ "${DRYRUN}" == "true" ]]; then
        if command -v sdiff > /dev/null 2>&1; then
            log 1
            log 1 "The following changes would be made (original vs new):"
            log 1 "--------------------------------------------------------"
            local sdiffArgs=("--minimal")

            # Adjust diff verbosity
            case $VERBOSE in
                [0-1])
                    sdiffArgs+=("--suppress-common-lines");;
                [2-9])
                    sdiffArgs+=("--left-column");;
            esac

            # Show user the diff
            sdiff "${sdiffArgs[@]}" "$ini_file" "$ini_file.tmp"
            local -r fileChanged=$?

            # Print summary of diff
            if [[ $fileChanged -eq 0 ]]; then
                log 0 "No changes detected"
            else
                log 1 "--------------------------------------------------------"
                log 0 "\nChanges detected"
            fi

            log 1
        fi

        # Clean up the temp file
        rm "$ini_file.tmp"
    else
        # This is the real deal
        # IDEA: We could offer an option to keep a backup of the original file
        mv "$ini_file.tmp" "$ini_file"
    fi
}

# Reads an INI-style file and loads the valid sections and keys into the commands
# associative array.  Keys within a section will have a '.'' as a delimiter
declare -A commands
# Stores descriptions for commands from '# description:' comments
declare -A commandDescriptions
# Stores the file:line location for each command
declare -A commandLocations
# Tracks definition order for commands and conditional entries so newer definitions win
declare -A commandOrder
# Monotonic counter for parsed definitions and conditional entries
declare -i __definition_order=0
# Array of all file paths found in the directory tree (used for definition lookups)
declare -a file_paths

# Global variable to track the current command being executed (for DRYRUN metadata lookup)
declare -g __current_cmd=""

# Conditional processing data structures
# Maps: blockId (file:startLine) -> condition string (e.g., "VAR==value" or "!VAR" or "VAR matches regex")
declare -A conditionalConditions
# Maps: blockId -> space-separated list of definition key=value pairs in this conditional block
declare -A conditionalDefinitions
# Map: blockId|key -> description for conditional-defined entries
declare -A conditionalDefDescriptions
# Array to track the order of conditional blocks for processing
declare -a conditionalBlockOrder
# Stack for nested conditional blocks
declare -a conditional_stack_ids
declare -a conditional_stack_defs

function trim() {
    local var="$1"
    var="${var#"${var%%[![:space:]]*}"}"
    var="${var%"${var##*[![:space:]]}"}"
    printf '%s' "$var"
}

function process_ini_file() {
    log 1 "Loading file: $1"
    local filepath="$1"

    # Detect the line break character for this file (LF vs CRLF) and warn the user if it is not LF
    if grep --quiet $'\r' --max-count 1 "$1"; then
        log 0 "\e[1;31mWARNING: Detected CRLF line endings in file '$1'.\nThis will cause issues when parsing and will be skipped.  Please convert the file to LF line breaks.\n\e[0m"
        return 1
    fi

    local section=""
    local pending_description=""
    local lineNumber=0
    # Variables for tracking conditional blocks
    local in_conditional=false
    local conditional_id=""
    local conditional_defs=()
    local conditional_stack_ids=()
    local conditional_stack_defs=()

    while IFS= read -r line <&3 || [[ -n "$line" ]]; do
        ((lineNumber++))

        # If the line ends with a continuation character '\', then read the next line and append it
        if [[ "$line" =~ \\[[:space:]]*$ ]]; then
            # Remove the trailing backslash and any whitespace, then append the next line
            line="${line%\\*}"
            line="${line#"${line%%[![:space:]]*}"}"
            log 2 "Line continuation detected at line $lineNumber: $line"

            {
                while IFS= read -r nextLine || [ -n "$nextLine" ]; do
                    ((lineNumber++)) # Keep incrementing the line during this loop

                    # Ignore comment lines starting with #
                    if [[ "$nextLine" =~ ^[[:space:]]*# ]]; then
                        log 3 "  Ignoring comment line in line continuation: $nextLine"
                    else
                        nextLine="${nextLine%"${nextLine##*[![:space:]]}"}" # Trim trailing whitespace
                        nextLine="${nextLine#"${nextLine%%[![:space:]]*}"}" # Trim leading whitespace
                        log 3 "  Appending line: $nextLine"
                        trimmedNextLine="${nextLine%%\\}"
                        line+="$trimmedNextLine"
                    fi

                    # If the line did not end with a continuation character, then we're finished
                    if [[ ! "$nextLine" =~ \\[[:space:]]*$ ]]; then
                        log 2 "Found last line of continuation at line $lineNumber: $nextLine"
                        break
                    fi
                done
            } <&3
        fi

        # Heredoc with newline: If the line ends with ''', then read until the next ''' and append it, preserving line wraps and whitespace
        if [[ "$line" =~ \'\'\'[[:space:]]*$ ]]; then
            log 2 "Found single quoted Heredoc starting at line: $line"
            line="${line%\'\'\'*}" # Remove the 3xSQ, but keep any trailing whitespace
            log 3 "Updated line: $line"

            {
                while IFS= read -r nextLine || [ -n "$nextLine" ]; do
                    ((lineNumber++)) # Keep incrementing the line during this loop

                    if [[ "$nextLine" =~ \'\'\'[[:space:]]*$ ]]; then
                        log 2 "----- Found Heredoc SQ end: ------"
                        nextLine="${nextLine%%\'\'\'}"
                        # nextLine="${nextLine%"${nextLine##*[![:space:]]}"}"
                        line+="${nextLine}\n"
                        break
                    else
                        log 3 "  Appending line: $nextLine"
                        line+="${nextLine}\n"
                        log 3 "    Updated line: $line"
                    fi
                done
            } <&3

            # Remove trailing new line char
            line="${line%\\n\\n}"
            line="${line%\\n}"
        fi

        # Heredoc without newline: If the line ends with """, then read until the next """ and append it into a single line
        if [[ "$line" =~ \"\"\"[[:space:]]*$ ]]; then
            log 2 "Found double quoted Heredoc starting at line: $line"
            line="${line%\"\"\"*}"
            line="${line%"${line##*[![:space:]]}"}"
            line="${line#"${line%%[![:space:]]*}"}"
            log 3 "Updated line: $line"

            {
                while IFS= read -r nextLine || [ -n "$nextLine" ]; do
                    ((lineNumber++)) # Keep incrementing the line during this loop

                    nextLine="${nextLine%"${nextLine##*[![:space:]]}"}" # Trim trailing whitespace
                    nextLine="${nextLine#"${nextLine%%[![:space:]]*}"}" # Trim leading whitespace

                    # Ignore comment lines starting with #
                    if [[ "$nextLine" =~ ^[[:space:]]*# ]]; then
                        log 3 "  Ignoring comment line in double quoted heredoc: $nextLine"
                        continue
                    fi

                    if [[ "$nextLine" =~ \"\"\"$ ]]; then
                        log 2 "----- Found Heredoc DQ end: ------"
                        nextLine=" ${nextLine%%\"\"\"}"
                        line+=" ${nextLine}"
                        break
                    else
                        log 3 "  Appending line: $nextLine"
                        line+=" ${nextLine}"
                        log 3 "    Updated line: $line"
                    fi
                done
            } <&3

            # Remove trailing new line char
            line="${line%\\n\\n}"
            line="${line%\\n}"
        fi

        # Check for description comment (must be before empty/comment check below)
        if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*description:[[:space:]]*(.*)$ ]]; then
            pending_description="${BASH_REMATCH[1]}"
            log 2 "Found description: '$pending_description'"
            continue
        fi

        # Skip empty lines and comments
        if [[ "$line" =~ ^[[:space:]]*$ ]] || [[ "$line" =~ ^[[:space:]]*# ]]; then
            continue
        fi

        log 2 " Entry - $line"

        # Check for include statements
        if [[ "$line" =~ ^include[[:space:]]+(.+)$ ]]; then
            include_file="${BASH_REMATCH[1]}"
            log 2 "Include Statement detected: Including file - '$include_file'"

            # Path may include tilde
            include_file=$(eval echo "$include_file")

            # Resolve relative paths based on the current file's directory
            if [[ ! "$include_file" = /* ]]; then
                include_file="$(dirname "$1")/$include_file"
            fi

            if [[ -f "$include_file" ]]; then
                process_ini_file "$include_file"
            else
                log 0 "  WARNING: Included file '$include_file' not found!"
            fi
            continue
        fi

        # Check for conditional control flow statements [IF], [ELSE IF], [ELSE], [FI]
        # This must be before section header check since both use brackets
        if [[ "$line" =~ ^[[:space:]]*\[IF[[:space:]]+(.+)\]$ ]]; then
            log 2 "Conditional [IF] block detected: ${BASH_REMATCH[1]}"

            # If we're already in a conditional, push current state to stack for nesting
            if [[ "$in_conditional" == "true" ]]; then
                conditional_stack_ids+=("$conditional_id")
                conditional_stack_defs+=("$(printf '%s\n' "${conditional_defs[@]}")")
            fi

            in_conditional=true
            conditional_id="${filepath}:${lineNumber}"
            conditional_defs=()
            # Extract and store the condition (everything between [IF and ])
            local condition_expr
            condition_expr="$(trim "${BASH_REMATCH[1]}")"
            conditionalConditions["$conditional_id"]="$condition_expr"
            log 2 "  Stored condition: '$condition_expr'"
            continue

        elif [[ "$line" =~ ^[[:space:]]*\[ELSE[[:space:]]*IF[[:space:]]+(.+)\]$ ]]; then
            log 2 "Conditional [ELSE IF] block detected: ${BASH_REMATCH[1]}"

            # Store previous block's definitions using newline as separator
            if [[ "$in_conditional" == "true" ]]; then
                if [[ -n "$conditional_id" ]]; then
                    conditionalDefinitions["$conditional_id"]="$(printf '%s\n' "${conditional_defs[@]}")"
                    log 2 "  Stored block definitions for: $conditional_id"
                    conditionalBlockOrder+=("$conditional_id")
                fi
            fi

            # Start new ELSE IF block
            in_conditional=true
            conditional_id="${filepath}:${lineNumber}"
            conditional_defs=()
            local condition_expr
            condition_expr="$(trim "${BASH_REMATCH[1]}")"
            # Store as "ELSE IF: ..." to distinguish from IF blocks during evaluation
            conditionalConditions["$conditional_id"]="ELSE IF: $condition_expr"
            log 2 "  Stored condition: 'ELSE IF: $condition_expr'"
            continue

        elif [[ "$line" =~ ^[[:space:]]*\[ELSE\]$ ]]; then
            log 2 "Conditional [ELSE] block detected"

            # Store previous block's definitions using newline as separator
            if [[ "$in_conditional" == "true" && -n "$conditional_id" ]]; then
                conditionalDefinitions["$conditional_id"]="$(printf '%s\n' "${conditional_defs[@]}")"
                log 2 "  Stored block definitions for: $conditional_id"
                conditionalBlockOrder+=("$conditional_id")
            fi

            # Start ELSE block (special condition: always true if reached)
            in_conditional=true
            conditional_id="${filepath}:${lineNumber}"
            conditional_defs=()
            conditionalConditions["$conditional_id"]="ELSE"  # Special marker
            log 2 "  ELSE block started"
            continue

        elif [[ "$line" =~ ^[[:space:]]*\[FI\]$ ]]; then
            log 2 "Conditional [FI] block terminator detected"

            # Store final block's definitions using newline as separator
            if [[ "$in_conditional" == "true" && -n "$conditional_id" ]]; then
                conditionalDefinitions["$conditional_id"]="$(printf '%s\n' "${conditional_defs[@]}")"
                log 2 "  Stored final block definitions for: $conditional_id"
                conditionalBlockOrder+=("$conditional_id")
            fi

            # Handle nested conditionals
            if [[ ${#conditional_stack_ids[@]} -gt 0 ]]; then
                # Pop from stack
                local last_idx=$((${#conditional_stack_ids[@]} - 1))
                conditional_id="${conditional_stack_ids[$last_idx]}"
                local defs_serialized="${conditional_stack_defs[$last_idx]}"
                unset 'conditional_stack_ids[$last_idx]'
                unset 'conditional_stack_defs[$last_idx]'

                conditional_defs=()
                if [[ -n "$defs_serialized" ]]; then
                    IFS=$'\n' read -r -d '' -a conditional_defs < <(printf '%s\0' "$defs_serialized")
                fi
            else
                in_conditional=false
                conditional_id=""
                conditional_defs=()
            fi
            continue
        fi

        # Check for section headers
        if [[ "$line" =~ ^\[.*\]$ ]]; then
            log 2 "Section Header detected: ${line:1:-1}"
            section=${line:1:-1}
            continue
        fi

        # Split the line into key and value
        IFS='=' read -r key value <<< "$line"
        # echo "     2 - $line"

        # Trim whitespace from key and value
        # key=$(echo "$key" | xargs)
        # value=$(echo "$value" | xargs)
        key="${key#"${key%%[![:space:]]*}"}"   # remove leading whitespace characters
        key="${key%"${key##*[![:space:]]}"}"   # remove trailing whitespace characters
        value="${value#"${value%%[![:space:]]*}"}"   # remove leading whitespace characters
        value="${value%"${value##*[![:space:]]}"}"   # remove trailing whitespace characters
        # echo "     3 - $key=$value"

        # If section is not empty, prepend it to the key with an underscore
        if [[ -n "$section" ]]; then
            key="${section}.${key}"
        fi

        # Replace any special variables in the value with their actual values
        # __DIRECTORY__ - The directory of the current file being processed
        if [[ "$value" =~ .*__[A-Z_]+__.* ]]; then
            log 2 "    Updating special variables in value: $value"
            value="${value//__DIRECTORY__/$(dirname "$1")}"

            log 2 "    Final value after special variable replacement: $value"
        fi

        # Before adding the key-value pair to the associative array,
        # add the key to the indexed array to preserve the order.
        if [[ "$in_conditional" == "true" ]]; then
            # We're inside a conditional block - accumulate the definition
            log 3 "  CONDITIONAL DEF:  ${key} = ${value}"
            __definition_order=$((__definition_order + 1))
            # Store parse order with the definition so newer defs always win
            conditional_defs+=("${__definition_order}	${key}=${value}")
            # If a description was pending for this definition, store it keyed by block and key
            if [[ -n "${pending_description}" ]]; then
                conditionalDefDescriptions["${conditional_id}|${key}"]="${pending_description}"
            fi
            # Reset pending description after using it for this definition
            pending_description=""
        else
            # Normal key-value pair (not in conditional block)
            if [[ ! -v commands["$key"] ]]; then
                log 3 "  ADD:      ${key} = ${value}"
            else
                log 2 "  REPLACE:  ${key} = ${value}"
                log 2 "              was '${commands[$key]}'"
            fi

            __definition_order=$((__definition_order + 1))
            commandOrder["$key"]=$__definition_order
            commands["$key"]=$value

            # Store the file location for this command (file:lineNumber)
            commandLocations["$key"]="${filepath}:${lineNumber}"

            # Store the description if one was provided
            if [[ -n "$pending_description" ]]; then
                commandDescriptions["$key"]="$pending_description"
                log 3 "  DESC:     ${key} = '${pending_description}'"
                pending_description=""  # Reset for next command
            else
                # Clear any previous description if this key doesn't have one
                commandDescriptions["$key"]=""
            fi
        fi
        # echo "     4 - $key=${commands["$key"]}"
    # done < "$1"
    done 3< <(cat "$1")
    log 2 "" # Add some spacing in extra verbose mode
}

# Walks the directory tree from the current directory to root and combines all
# keys and values found in ${MY_CUSTOM_FILE} files.  The values closest to the
# current directory are used
function load_my_custom_files() {
    # Clear any previously loaded data structures
    commands=()
    commandDescriptions=()
    commandLocations=()
    commandOrder=()
    conditionalConditions=()
    conditionalDefinitions=()
    conditionalBlockOrder=()
    __definition_order=0
    file_paths=()  # Clear the global file_paths array

    # Start in the current directory and move up the directory tree
    dir=$(pwd)

    # Find all files in the directory tree
    log 1 "Searching for ${MY_CUSTOM_FILE} files in the directory tree..."
    while [ "$dir" != "/" ]; do
        # Add .local files BEFORE main files so in reverse iteration, main is processed first, then .local (giving .local priority)
        log 2 "Checking for local override file: ${MY_CUSTOM_FILE}.local"
        if [[ -f "$dir/${MY_CUSTOM_FILE}.local" ]]; then
            log 3 "  Found local override file!"
            file_paths+=("$dir/${MY_CUSTOM_FILE}.local")
        fi
        # Try without the trailing 's' for legacy local file
        log 2 "Checking for legacy local override file: ${MY_CUSTOM_FILE%?}.local"
        if [[ -f "$dir/${MY_CUSTOM_FILE%?}.local" ]]; then
            log 3 "  Found legacy local override file!"
            file_paths+=("$dir/${MY_CUSTOM_FILE%?}.local")
        fi
        # Then add main file
        log 2 "Checking for file: ${MY_CUSTOM_FILE}"
        if [[ -f "$dir/${MY_CUSTOM_FILE}" ]]; then
            log 3 "  Found file!"
            file_paths+=("$dir/${MY_CUSTOM_FILE}")
        fi
        # Try without the trailing 's' for backwards compatibility
        log 2 "Checking for legacy file: ${MY_CUSTOM_FILE%?}"
        if [[ -f "$dir/${MY_CUSTOM_FILE%?}" ]]; then
            log 3 "  Found legacy file!"
            file_paths+=("$dir/${MY_CUSTOM_FILE%?}")
        fi
        dir=$(dirname "$dir")
    done

    # Always process the home dir files
    # Support both the current and legacy file name for backwards compatibility
    # Add .local override file BEFORE main home file
    if [ -f "${HOME}/${MY_CUSTOM_FILE}.local" ]; then
        file_paths+=("${HOME}/${MY_CUSTOM_FILE}.local")
    elif [ -f "${HOME}/${MY_CUSTOM_FILE%?}.local" ]; then
        file_paths+=("${HOME}/${MY_CUSTOM_FILE%?}.local")
    fi
    # Then add main home file
    if [ -f "${HOME}/${MY_CUSTOM_FILE}" ]; then
        file_paths+=("${HOME}/${MY_CUSTOM_FILE}")
    elif [ -f "${HOME}/${MY_CUSTOM_FILE%?}" ]; then
        file_paths+=("${HOME}/${MY_CUSTOM_FILE%?}")
    fi

    # Remove consecutive duplicate entries (if executed in a subdirectory of ~)
    # If this re-orders the list, then consider using https://stackoverflow.com/a/54797762/2136313 method
    # Remove only consecutive duplicate entries (preserve order, allow non-consecutive duplicates)
    unique_file_paths=()
    prev=""
    for fp in "${file_paths[@]}"; do
        if [[ "$fp" != "$prev" ]]; then
            unique_file_paths+=("$fp")
        fi
        prev="$fp"
    done
    file_paths=("${unique_file_paths[@]}")
    unset unique_file_paths
    unset prev

    # Process the files in reverse order
    for (( idx=${#file_paths[@]}-1 ; idx>=0 ; idx-- )) ; do
        process_ini_file "${file_paths[idx]}"
    done

    if [[ -z ${file_paths[0]} ]]; then
        log 1 "No ${MY_CUSTOM_FILE} files were found in the directory tree"
        return 1
    fi

    log 1 "" # Add spacing in verbose mode
    return 0
}

# Searches the commands array for the requested key
# If found, will set the 'foundKey_value'
foundKey_value=""
function findKey() {
    local cmd=$1
    log 1 "Searching for cmd: $cmd"
    foundKey_value=""  # Clear previous search result

    if [[ -v commands["$cmd"] ]]; then
        foundKey_value="${commands[$cmd]}"
        log 1 "      Found: $foundKey_value"
        return 0
    fi

    return 1
}

# Evaluates all conditional blocks that were parsed from .myCommands files
# and merges matching conditional definitions into the commands array
# Properly handles IF/ELSE IF/ELSE chains - once one matches, rest are skipped
function evaluate_conditionals() {
    log 1 "Evaluating conditional blocks..."
    local total_blocks=${#conditionalBlockOrder[@]}
    log 1 "  Found $total_blocks conditional blocks to evaluate"

    if [[ $total_blocks -eq 0 ]]; then
        log 1 "  No conditional blocks to evaluate"
        return 0
    fi

    # Track which IF blocks have already matched (by their first block in the chain)
    declare -A chain_head_matched  # Tracks which chain heads have matched
    local current_chain_head=""   # Track the first block ID of current chain

    # Process each conditional block
    for block_id in "${conditionalBlockOrder[@]}"; do
        local condition="${conditionalConditions[$block_id]}"
        local defs="${conditionalDefinitions[$block_id]}"

        log 1 "  Evaluating block: $block_id"
        log 2 "    Condition: $condition"
        log 3 "    Definitions: $defs"

        local condition_result=false
        local should_apply=true

        # Track chain membership: IF starts new chain, ELSE/ELSE IF continue it
        if [[ "$condition" != "ELSE" && ! "$condition" =~ ^ELSE\ IF ]]; then
            # This is an IF block - start of a new chain
            current_chain_head="$block_id"
            chain_head_matched["$current_chain_head"]=""  # Reset for new chain
            log 3 "    Starting new conditional chain: $current_chain_head"
        fi

        # Check if this chain has already matched
        if [[ -n "${chain_head_matched[$current_chain_head]}" ]] && [[ "${chain_head_matched[$current_chain_head]}" == "true" ]]; then
            log 3 "    Skipping block - another block in same chain already matched"
            should_apply=false
        fi

        if [[ "$should_apply" == "true" ]]; then
            # Special case: ELSE block (always true if reached and chain hasn't matched)
            if [[ "$condition" == "ELSE" ]]; then
                log 2 "    ELSE block - evaluating as true"
                condition_result=true
            else
                # Evaluate the condition using global var to avoid capturing log output via $()
                __evaluate_condition "$condition"
                condition_result="$__condition_result"
            fi

            log 2 "    Condition result: $condition_result"

            # If condition is true, merge the definitions and mark chain as matched
            if [[ "$condition_result" == "true" ]]; then
                log 2 "    Applying conditional definitions..."
                # Split the definitions by newline (each definition is on its own line in the string)
                while IFS= read -r def; do
                    if [[ -z "$def" ]]; then
                        continue
                    fi

                    # Support new tab-separated format: key\tdescription\tvalue
                    # Legacy format: def is "key=value"
                    local def_order=0
                    local raw_def="$def"
                    if [[ "$def" == *$'\t'* ]]; then
                        def_order="${def%%$'\t'*}"
                        raw_def="${def#*$'\t'}"
                    fi

                    IFS='=' read -r key value <<< "$raw_def"
                    desc="${conditionalDefDescriptions["${block_id}|${key}"]:-}"

                    # Trim whitespace
                    key="${key#"${key%%[![:space:]]*}"}"
                    key="${key%"${key##*[![:space:]]}"}"
                    value="${value#"${value%%[![:space:]]*}"}"
                    value="${value%"${value##*[![:space:]]}"}"
                    desc="${desc#"${desc%%[![:space:]]*}"}"
                    desc="${desc%"${desc##*[![:space:]]}"}"

                    if [[ -n "${commandOrder["$key"]}" ]] && [[ "${commandOrder["$key"]}" -gt "$def_order" ]]; then
                        log 3 "      Skipping outdated conditional definition for $key (existing order ${commandOrder["$key"]} > ${def_order})"
                        continue
                    fi

                    log 3 "      Applying: $key = $value"
                    commandOrder["$key"]=$def_order
                    commands["$key"]="$value"
                    # Preserve description for conditional-defined commands
                    commandDescriptions["$key"]="$desc"
                    # Record location as the conditional block id (file:startLine)
                    commandLocations["$key"]="$block_id"
                done <<< "$defs"

                # Mark this chain as matched so subsequent blocks in chain are skipped
                chain_head_matched["$current_chain_head"]="true"
            fi
        fi
    done

    log 1 "  Completed conditional evaluation"
    return 0
}

# Helper function to evaluate a single condition expression
# Supports: VAR==value, VAR!=value, VAR matches regex, VAR (non-empty), !VAR (empty)
# Result is stored in global __condition_result ("true" or "false") to avoid
# capturing log output via command substitution $()
declare -g __condition_result="false"
function __evaluate_condition() {
    local condition="$1"
    __condition_result="false"
    log 3 "    __evaluate_condition: '$condition'"

    # Strip "ELSE IF: " prefix if present (used to distinguish from IF blocks)
    if [[ "$condition" =~ ^ELSE\ IF:\ (.*)$ ]]; then
        condition="${BASH_REMATCH[1]}"
        log 3 "      Stripped ELSE IF prefix, evaluating: '$condition'"
    fi

    # Trim whitespace
    condition="$(trim "$condition")"

    # Check for existence (negative) - [IF !$VAR]
    if [[ "$condition" =~ ^![[:space:]]*\$([a-zA-Z_][a-zA-Z0-9_]*)$ ]]; then
        local var_name="${BASH_REMATCH[1]}"
        log 3 "      Checking if variable is empty: $var_name"

        if findKey "$var_name"; then
            local var_value="$foundKey_value"
            if [[ -z "$var_value" ]]; then
                __condition_result="true"
                return 0
            fi
        else
            # Variable doesn't exist, so it's "empty"
            __condition_result="true"
            return 0
        fi
        __condition_result="false"
        return 0
    fi

    # Check for existence (positive) - [IF $VAR]
    if [[ "$condition" =~ ^\$([a-zA-Z_][a-zA-Z0-9_]*)$ ]]; then
        local var_name="${BASH_REMATCH[1]}"
        log 3 "      Checking if variable is non-empty: $var_name"

        if findKey "$var_name"; then
            local var_value="$foundKey_value"
            if [[ -n "$var_value" ]]; then
                __condition_result="true"
                return 0
            fi
        fi
        __condition_result="false"
        return 0
    fi

    # Check for regex match - VAR matches "pattern"
    if [[ "$condition" =~ ^([[:space:]]*)\$([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]+matches[[:space:]]+\"(.*)\"[[:space:]]*$ ]]; then
        local var_name="${BASH_REMATCH[2]}"
        local pattern="${BASH_REMATCH[3]}"
        log 3 "      Checking regex match: $var_name matches \"$pattern\""

        if findKey "$var_name"; then
            local var_value="$foundKey_value"
            if [[ "$var_value" =~ $pattern ]]; then
                __condition_result="true"
                return 0
            fi
        fi
        __condition_result="false"
        return 0
    fi

    # Check for equality - VAR == "value"
    if [[ "$condition" =~ ^([[:space:]]*)\$([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*==[[:space:]]*\"(.*)\"[[:space:]]*$ ]]; then
        local var_name="${BASH_REMATCH[2]}"
        local expected_value="${BASH_REMATCH[3]}"
        log 3 "      Checking equality: $var_name == \"$expected_value\""

        if findKey "$var_name"; then
            local var_value="$foundKey_value"
            if [[ "$var_value" == "$expected_value" ]]; then
                __condition_result="true"
                return 0
            fi
        fi
        __condition_result="false"
        return 0
    fi

    # Check for inequality - VAR != "value"
    if [[ "$condition" =~ ^([[:space:]]*)\$([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*!=[[:space:]]*\"(.*)\"[[:space:]]*$ ]]; then
        local var_name="${BASH_REMATCH[2]}"
        local expected_value="${BASH_REMATCH[3]}"
        log 3 "      Checking inequality: $var_name != \"$expected_value\""

        if findKey "$var_name"; then
            local var_value="$foundKey_value"
            if [[ "$var_value" != "$expected_value" ]]; then
                __condition_result="true"
                return 0
            fi
        else
            # Variable doesn't exist, so it's != to any value
            __condition_result="true"
            return 0
        fi
        __condition_result="false"
        return 0
    fi

    log 0 "WARNING: Could not parse condition: '$condition'"
    __condition_result="false"
    return 0
}


# Adds a new key-value pair to the ${MY_CUSTOM_FILE} file in the current directory
#  <string> key - The key to add
#  <string> value - The value to associate with the key
function set_key_value() {
    local key=$1
    shift
    local value="$1 " # The first element should always be a command so don't quote
    shift

    # Loop through each additional argument and append it to the value string
    for arg in "$@"; do
        # If the argument contains spaces, enclose it in double quotes
        if [[ $arg == *" "* ]]; then
            value+="\"${arg//\\ / }\" "
        else
            value+="$arg "
        fi
    done

    # Remove the trailing space from the value string
    value=${value% }

    log 1 "Adding key: '${key}' with a value of '${value}'\n   to '${MY_CUSTOM_FILE}'..."

    # Use set_ini_value to add or update the key-value pair under the 'commands' section
    set_ini_value "${MY_CUSTOM_FILE}" "$key" "$value"

    log 3 "Updated ${MY_CUSTOM_FILE} content:"
    log 3 "$(cat "${MY_CUSTOM_FILE}" )"
    log 3
}

# Function to list all keys from the ${MY_CUSTOM_FILE} files in the current directory tree
# If the -l argument is given, output will not be piped to column.
# If the -d argument is given, descriptions will be included in the output.
# NOTE: Only keys beginning with a lower-case letter will be printed unless `-a` option is specified
#  Keys starting with uppercase are considered variables
function list_keys() {
    local indent="    "
    readonly indent
    local use_column=true
    local include_const=false
    local show_descriptions=false
    local filter_pattern=""

    # Check for args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            "-l")
                use_column=false;;

            "-a")
                include_const=true;;

            "-d")
                show_descriptions=true;;

            *)
                filter_pattern="$1";;
        esac

        shift
    done

    log 1 "Filter Pattern: $filter_pattern"
    log 1 "Show Descriptions: $show_descriptions"

    # Handle when column util is not installed
    if [[ $(type -t column) != "file" ]]; then
        use_column=false
    fi

    if load_my_custom_files; then
        # Evaluate conditional definitions so list output reflects merged state
        evaluate_conditionals

        # Determine if variables (uppercase) words should be included
        if [[ "$include_const" == "true" ]]; then
            log 1 "Including Vars"
            grepCMD='grep "^[a-zA-Z]"'
        else
            log 1 "Excluding Vars"
            grepCMD='grep "^[a-z][^.]*$\|\\.[^.]*[a-z]"'
        fi

        local words
        words=$(printf "%s\n" "${!commands[@]}" | eval "${grepCMD}" | sort)

        # Apply a filter if a partial word was given (for autocomplete)
        if [[ -n "$filter_pattern" ]]; then
            words=$(echo "$words" | grep "${filter_pattern}")
        fi

        # If there are no words, then print "Nothing Found"
        if [[ -z "$words" ]]; then
            log 0 "No commands found matching the filter '${filter_pattern}'"
        else
            # If showing descriptions, format the output with two columns
            if [[ "$show_descriptions" == true ]]; then
                log 0 "The following commands are available:"

                # Build array of key|description pairs for columnar output
                declare -a desc_pairs=()
                while IFS= read -r word; do
                    local desc="${commandDescriptions["$word"]:-}"
                    desc_pairs+=("$word|$desc")
                done <<< "$words"

                # Try to use column utility if available and not in line view mode
                if [[ "$use_column" == true ]] && [[ $(type -t column) == "file" ]]; then
                    printf "%s\n" "${desc_pairs[@]}" | column -t -s "|"
                else
                    # Fallback: use printf for manual formatting without column utility
                    # Find the longest key name for padding
                    local max_key_len=0
                    while IFS= read -r word; do
                        if [[ ${#word} -gt $max_key_len ]]; then
                            max_key_len=${#word}
                        fi
                    done <<< "$words"

                    # Print with padding
                    for pair in "${desc_pairs[@]}"; do
                        IFS='|' read -r key desc <<< "$pair"
                        printf "%-${max_key_len}s  %s\n" "$key" "$desc"
                    done
                fi
            else
                # Determine if output should be formatted in columns or a list
                if [[ "$use_column" == true ]]; then
                    if [ -v COLUMN_WIDTH ]; then
                        COLUMN_ARG="-c ${COLUMN_WIDTH}"
                    fi

                    outputCMD="column ${COLUMN_ARG}"
                else
                    outputCMD="sed 's/^/${indent}/'"
                fi

                log 0 "The following commands are available:"
                echo "$words" | eval "${outputCMD}"
            fi

            # printf "%s\n" "${!commands[@]}" | eval ${grepCMD} | sort | eval ${outputCMD}
        fi

    else
        log 1 "No ${MY_CUSTOM_FILE} file was found in the current directory tree."
        return 1
    fi
}

# Function to locate the given key from the ${MY_CUSTOM_FILE} files in the directory tree
function get_key_definition() {
    local defKey=$1
    shift

    # Check if defKey is empty
    if [[ -z "$defKey" ]]; then
        log 0 "Missing key argument!"
        log 0 "  Usage: ${__ScriptName} definition <key>"
        log 0 "  For full details, see '${__ScriptName} help'"
        return 1
    fi

    # Load files to populate commands and conditionals arrays
    load_my_custom_files > /dev/null 2>&1
    evaluate_conditionals > /dev/null 2>&1

    # Check if the key exists (in either commands or conditionals)
    if [[ ! -v commands["$defKey"] ]]; then
        # Check if it exists in conditionals
        local found_in_conditionals=false
        for block_id in "${conditionalBlockOrder[@]}"; do
            local defs="${conditionalDefinitions["$block_id"]}"
            if [[ "$defs" =~ $defKey ]]; then
                found_in_conditionals=true
                break
            fi
        done
        
        if [[ "$found_in_conditionals" == "false" ]]; then
            log 1 "Key not found: $defKey\n"
            return 1
        fi
    fi

    # Extract section and key from the defKey (format: "section.key" or just "key")
    local section=""
    local key="$defKey"
    if [[ "$defKey" =~ ^(.+)\.([^.]+)$ ]]; then
        section="${BASH_REMATCH[1]}"
        key="${BASH_REMATCH[2]}"
    fi

    # Re-parse all files to find all locations where this key appears
    declare -a definitions
    
    for filepath in "${file_paths[@]}"; do
        [[ ! -f "$filepath" ]] && continue
        
        local lineNumber=0
        local file_section=""
        local in_conditional=false
        # local conditional_line=0
        
        while IFS= read -r line || [[ -n "$line" ]]; do
            ((lineNumber++))
            
            # Skip empty lines and comments
            if [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]]; then
                # Preserve description comments for non-conditional entries
                if [[ "$line" =~ ^[[:space:]]*#[[:space:]]*description:[[:space:]]*(.*)$ ]]; then
                    :  # Description will be picked up from commandDescriptions
                fi
                continue
            fi
            
            # Check for conditional start/end
            if [[ "$line" =~ ^[[:space:]]*\[(IF|ELSE|FI|ELSE\ IF) ]]; then
                in_conditional=true
                # conditional_line=$lineNumber
                continue
            fi
            
            # Check for section header [section]
            if [[ "$line" =~ ^[[:space:]]*\[([^\]]+)\][[:space:]]*$ ]]; then
                file_section="${BASH_REMATCH[1]}"
                continue
            fi
            
            # Parse key=value pairs
            if [[ "$line" =~ ^[[:space:]]*([^=]+)=(.*)$ ]]; then
                local line_key="${BASH_REMATCH[1]}"
                line_key="${line_key#"${line_key%%[![:space:]]*}"}"  # Trim leading
                line_key="${line_key%"${line_key##*[![:space:]]}"}"  # Trim trailing
                
                local line_value="${BASH_REMATCH[2]}"
                
                # Check if this matches the key we're looking for
                if [[ "$line_key" == "$key" ]]; then
                    # Check if section matches (if a section was specified)
                    if [[ -z "$section" || "$file_section" == "$section" ]]; then
                        local desc="${commandDescriptions["$defKey"]:-}"
                        
                        # Format the definition entry
                        local entry
                        if [[ -n "$file_section" ]]; then
                            entry="$filepath:$lineNumber|[$file_section]⇒ $line_key||$desc||$line_value"
                        else
                            entry="$filepath:$lineNumber|$line_key||$desc||$line_value"
                        fi
                        definitions+=("$entry")
                    fi
                fi
            fi
        done < "$filepath"
    done

    # Also look for the key in conditional definitions and add them
    for block_id in "${conditionalBlockOrder[@]}"; do
        local condition="${conditionalConditions["$block_id"]}"
        local defs="${conditionalDefinitions["$block_id"]}"
        local block_file="${block_id%:*}"
        local block_line="${block_id##*:}"
        
        # Parse the conditional definitions to find our key
        while IFS= read -r def_line; do
            [[ -z "$def_line" ]] && continue
            
            # Parse "order	key=value" format
            if [[ "$def_line" =~ ^[0-9]+[[:space:]]+([^=]+)=(.*)$ ]]; then
                local def_key="${BASH_REMATCH[1]}"
                local def_value="${BASH_REMATCH[2]}"
                
                if [[ "$def_key" == "$defKey" ]]; then
                    # Extract section and key
                    local cond_section=""
                    local cond_key="$def_key"
                    if [[ "$def_key" =~ ^(.+)\.([^.]+)$ ]]; then
                        cond_section="${BASH_REMATCH[1]}"
                        cond_key="${BASH_REMATCH[2]}"
                    fi
                    
                    # Get description if available
                    local cond_desc="${commandDescriptions["$defKey"]:-}"
                    
                    # Format: show condition in the location part
                    local entry
                    if [[ -n "$cond_section" ]]; then
                        entry="$block_file:$block_line|[$cond_section]⇒ $cond_key||$cond_desc||$def_value"
                    else
                        entry="$block_file:$block_line|$cond_key||$cond_desc||$def_value"
                    fi
                    definitions+=("$entry")
                fi
            fi
        done <<< "$defs"
    done

    # Display all definitions found (in reverse order: root → PWD)
    if [[ ${#definitions[@]} -eq 0 ]]; then
        log 1 "No definitions found for: $defKey\n"
        return 1
    fi

    if [[ $(type -t column) == "file" ]]; then
        columnCMD='column -t -s "|"'
    else
        columnCMD="sed 's/|/\t/g'"
    fi

    # Output all definitions in reverse order (root first)
    for (( i=${#definitions[@]}-1 ; i>=0 ; i-- )) ; do
        entry="${definitions[$i]}"
        log 0 "${entry//\\n/\\\\n}" | eval "${columnCMD}"
    done

    log 2 "" # Add spacing in verbose mode
    return 0

}

# Builds a merged version of the ${MY_CUSTOM_FILE} files in the directory tree
# then if the give key is found, will execute the defined value
function find_and_run_cmd() {
    # The command to search for
    cmd=$1
    shift

    load_my_custom_files

    # Evaluate any conditional blocks that were parsed from the .myCommands files
    evaluate_conditionals

    # Now that we have the combined keys, search for the key entered
    if findKey "$cmd"; then
        log 1 "Found value for '$cmd': $foundKey_value"

        # If definition preview mode is enabled, show the definition and exit
        if [[ "${DEFINITION_PREVIEW}" == "true" ]]; then
            get_key_definition "$cmd"
            return 0
        fi

        binary_cmd="$foundKey_value"
        local max_loops=50

        # Resolve MyCE nested invocation syntax: ${commandKey arg1 arg2}
        # Example: inDir=${reDir Hello}
        __expand_nested_invocations "$binary_cmd"
        binary_cmd="$__nested_expanded_cmd"

        # Replace positional/named references via shared helper.
        __apply_args_to_template "$binary_cmd" "false" "$@"
        binary_cmd="$__template_expanded_cmd"

        # Rebuild remaining args from helper outputs so runCMD behavior stays unchanged.
        local remaining_positional=("${__template_remaining_positional[@]}")
        local unconsumed_named_args=("${__template_unconsumed_named[@]}")
        set -- "${remaining_positional[@]}"

        log 3 "Remaining arguments: $*"
        log 3 "Current evolution of command: $binary_cmd"

        local loopCount=0
        # Look for variable references in the command
        #  - Matches ${VAR_NAME}, ${VAR_NAME:-default}, or $VAR_NAME patterns
        #  - Excludes those starting with an escaped dollar sign (\$)
        # This regex ensures we match variables at the start of the string as well
        while :; do
            # Only match unescaped $ (not preceded by a backslash)
            if [[ "$binary_cmd" =~ (^|[^\\])(\$([a-zA-Z_]+|\{([a-zA-Z][^:}]+)(:[^}]+)?\}?)) ]]; then
                prefix="${BASH_REMATCH[1]}"
                slug="${BASH_REMATCH[2]}"

                if [[ -n ${BASH_REMATCH[4]} ]]; then
                # If the variable is surrounded by {}, it starts with [a-zA-Z_] and includes any character except for }
                    var_name=${BASH_REMATCH[4]}
                    log 3 "      Found variable inside curly brackets: ${var_name}"

                else
                    # If the variable is not surrounded by {}, it follows the more restrictive pattern
                    var_name=${BASH_REMATCH[3]}
                    log 3 "      Found variable: ${var_name}"
                fi

                # Get the value of the variable from the loaded commands
                log 3 "Variable Reference Match Results - prefix='${prefix}'; slug='${slug}'; var_name='${var_name}'"
                log 2 "    Trying to replace '$slug' with variable: $var_name"
                before="$binary_cmd"
                if findKey "$var_name"; then
                    log 2 "    Found key: $foundKey_value"
                    # Replace only the first occurrence after the prefix
                    binary_cmd="${binary_cmd/"$prefix$slug"/"$prefix$foundKey_value"}"
                else
                    log 1 "The referenced variable ($slug) was not defined! Passing through to eval"
                    # Replace only the first occurrence after the prefix with escaped $
                    binary_cmd="${binary_cmd/"$prefix$slug"/"${prefix}\\$slug"}"
                fi
                log 2 "    New:  $binary_cmd"

                # Avoid an infinite loop
                ((loopCount++))
                if ((loopCount >= max_loops)); then
                    log 0 "There appears to be an infinite loop in your command references!"
                    exit 1
                fi

                # If no progress, break
                if [[ "$binary_cmd" == "$before" ]]; then
                    break
                fi
            else
                break
            fi
        done

        # Now that we've replaced all known variables,
        # Remove the escaped references to allow passing through
        binary_cmd="${binary_cmd//\\\$/$}"
        log 2 "Expanded command to be executed:\n    $binary_cmd\n"
        log 3 "Loops Taken: $loopCount"

        # Run the extracted command with the additional arguments
        __current_cmd="$cmd"  # Set global for DRYRUN metadata lookup
        local args
        if [ $# -gt 0 ] || [[ ${#unconsumed_named_args[@]} -gt 0 ]]; then
            # Combine remaining positional args with unconsumed named args
            local all_remaining_args=("$@" "${unconsumed_named_args[@]}")
            printf -v args '%q ' "${all_remaining_args[@]}"
        fi
        runCMD "$binary_cmd" "$args"

    else
        # If the key was not found in any ${MY_CUSTOM_FILE} files
        if [[ "${DEFINITION_PREVIEW}" == "true" ]]; then
            log 0 "No definition found for '$cmd'"
            return 1
        fi
        log 1 "No ${MY_CUSTOM_FILE} file was found in the current directory tree containing '$cmd'\n"
        __current_cmd=""  # Clear for utility command (no metadata available)
        runCMD "$cmd" "$@"
    fi
}

# Download and extract the latest releast from github to a temp folder
function download_latest_release() {
    local temp_file="$1"
    local repo="$2"
    local tag="${3:latest}"

    # Get the latest release files into a tmp location
    log 1 "Checking ${repo} for ${tag} release..."

    case ${tag} in
        latest|release|released )
            tag="$(curl -Ls -o /dev/null -w '%{url_effective}' "${repo}/releases/latest" | awk -F'/' '{print $NF}')"
            log 1 "Found Latest Release Tag: ${tag}"
            local github_path="${repo}/archive/refs/tags/${tag}.tar.gz"
            archive_root="MyCE-${tag#v}"
            ;;

        head|main )
            log 1 "Using head of Main branch"
            local github_path="${repo}/archive/refs/heads/main.tar.gz"
            tag=main
            archive_root="MyCE-main"
            ;;

        # Assume the given value is a version number
        * )
            log 1 "Using Release Tag: ${tag}"
            local github_path="${repo}/archive/refs/tags/${tag}.tar.gz"
            archive_root="MyCE-${tag#v}"
            ;;
    esac


    # Download the latest version from the github repo
    log 0 "\nDownloading latest version from GitHub..."
    log 0 "    ${github_path}\n"


    # Example: https://github.com/jerrens/MyCE/archive/refs/tags/v26.2.6.tar.gz`
    log 2 "Storing temp file at: ${temp_file}"
    if ! wget --output-document "${temp_file}" --quiet "${github_path}"; then
        log 0 "Failed to download the latest version from ${github_path}"
        exit 1
    fi

    # Extract the downloaded archive
    # archive_root="MyCE-${tag#v}"
    tar -xzf "${temp_file}" --directory /tmp --wildcards "${archive_root}/my" --wildcards "${archive_root}/auto-complete/*"
}


# Update the script with the latest version
function update_script() {
    tag=released

    # Grab the options
    while [ $# -gt 0 ]; do
        # echo "Option: $1"
        normalized_arg=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
        case ${normalized_arg} in
            update ) ;; # Expected for first arg
            diff ) show_diff=true ;;
            head|main ) tag="head" ;;
            released ) tag="released" ;;

            # Assume the given value is a version number (vYY.mm.dd), head, main, or released
            * ) tag="${1}" ;;
        esac
        shift
    done

    github_path=https://raw.githubusercontent.com/jerrens/MyCE/refs/heads/main/my

    # Determine where we should install the update
    # If running this script in a dev env (running with `./my ...`), then we don't want to accidentally replace these dev changes with the version from the repo release
    # Expected location is typically: /usr/local/bin/my
    exe_basename=$(basename "$0" 2> /dev/null) # Get the filename of the exe running
    # Handle if not installed in a PATH location (running locally), by referencing the executing script
    install_path=$( which "${exe_basename}" 2> /dev/null )
    install_path=${install_path:-$0}

    local repo=https://github.com/jerrens/MyCE
    local temp_file="/tmp/${__AppName}.${tag}.tar.gz"


    # Check for internet access
    if ! ping -q -c 1 -W 1 8.8.8.8 >/dev/null; then
        log 0 "No internet connection!"
        exit 1
    fi

    # If 'diff' is requested, then download and show the diff
    if [[ -n "$show_diff" ]]; then
        log 2 "User requested to view diff"
        # Download and extract the latest released files
        download_latest_release "${temp_file}" "${repo}" "${tag}"

        my_file_path="/tmp/${archive_root}/my"

        if ! diff -q "${my_file_path}" "${install_path}" >/dev/null; then
            # Show the diff
            log 0 "The following are the changes between your current version and the latest version on GitHub:\n"
            sdiff -s --width=200 "${install_path}" "${my_file_path}"

            log 0 "\n---------------------------------------------------------------------------"
            log 0 "You can run '${__ScriptName} update' to update to the latest version"
        else
            log 0 "You are already running the latest version!"
        fi
        log 0

        # Remove the temp file
        rm "${temp_file}"
        rm -R "/tmp/${archive_root}"
        exit 0
    fi

    if [ "$EUID" -ne 0 ]; then
        log 0 "This should be run as root.  Attempting to elevate permissions..."
        log 1 "runCMD XXdo $0 $__origArgs"

        # Re-run this command as sudo
        if [[ $(type -t dzdo) == "file" ]]; then
            log 2 "Using dzdo for privilege escalation"
            runCMD dzdo "$0" "$__origArgs"
        else
            log 2 "Using sudo for privilege escalation"
            runCMD sudo "$0" "$__origArgs"
        fi
        exit
    fi
    # NOTE: Root Level if here

    log 1 "Downloading and installing MyCE from GitHub..."
    log 2 "Temp file will be stored at: ${temp_file}"
    log 2 "Repo: ${repo}"
    log 2 "Tag: ${tag}"
    download_latest_release "${temp_file}" "${repo}" "${tag}"

    log 0 "Updating from v${__Version} to ${tag}..."

    # Move 'my' and make it executable
    log 1 "Installing to ${install_path}..."
    runCMD mv --force "/tmp/${archive_root}/my" "${install_path}"
    log 1 "\nModifying permissions..."
    runCMD chmod a+x "${install_path}"

    # Determine installation auto-completion based on shell type
    local src_file dest_file completion_dir
    if [[ $__Shell == "zsh" ]]; then
        src_file="/tmp/${archive_root}/auto-complete/_my.zsh"
        dest_file="/usr/local/share/zsh/site-functions/_my"
        completion_dir="/usr/local/share/zsh/site-functions"
    else # Assume BASH
        src_file="/tmp/${archive_root}/auto-complete/my.bash"
        dest_file="/etc/bash_completion.d/my.bash_completion"
        completion_dir="/etc/bash_completion.d"
    fi

    # Now that we know the shell type, move the appropriate completion file and set permissions
    if [[ -n "$src_file" && -n "$dest_file" && -d "${completion_dir}" ]]; then
        log 1 "Updating ${__Shell} completion file at ${completion_dir}..."
        runCMD mv --force "$src_file" "$dest_file"
        runCMD chmod 644 "$dest_file"
    fi

    log 0 "Update finished!"
    log 2 "Removing temp file"
    rm "${temp_file}"
    rm -R "/tmp/${archive_root}"
    exit 0
}

# Entry point of the program
# Check the first arg to determine what action to take
function main() {
    # Check for command line args
    case "$1" in
        "")
            log 0 "Missing arguments!"
            log 0 "  For syntax help, run the command '${__ScriptName} help'"

            if [[ ${VERBOSE} -gt 0 ]]; then print_usage false; fi
            exit 1
            ;;

        help)
            print_usage true
            exit 0
            ;;

        version)
            log 0 "${__Version}"
            exit 0
            ;;

        set)
            shift # Remove the 'set' command
            if [[ -z "$1" || -z "$2" ]]; then
                log 0 "Missing key or value!"
                log 0 "  Usage: ${__ScriptName} set <key> <value>"
                exit 1
            fi
            set_key_value "$1" "${@:2}"
            exit 0
            ;;

        list)
            shift
            list_keys "$@"
            exit 0
            ;;

        definition)
            shift
            get_key_definition "$@"
            exit 0
            ;;

        update)
            update_script "$@";;

        *)
            find_and_run_cmd "$@"
            ;;
    esac
}

# Call main function and pass all (remaining) CL args
main "$@"
exit $?
